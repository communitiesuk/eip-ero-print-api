<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">

    <changeSet id="0040_add_request_for_certificate_status" author="stephen.penney@softwire.com" context="ddl">
        <preConditions onFail="MARK_RAN">
            <not>
                <indexExists tableName="certificate" indexName="certificate_status_idx" />
            </not>
        </preConditions>

        <createIndex tableName="certificate" indexName="certificate_status_idx">
            <column name="status"/>
        </createIndex>

        <rollback>
            <dropIndex tableName="certificate" indexName="certificate_status_idx"/>
        </rollback>
    </changeSet>
</databaseChangeLog>
